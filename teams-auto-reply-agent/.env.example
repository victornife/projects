# Microsoft App Registration (Azure)
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# The public base URL of this service (used for webhook validation)
PUBLIC_BASE_URL=https://your-public-domain

# OpenAI API key
OPENAI_API_KEY=your-openai-api-key

# Optional OpenAI model name
OPENAI_MODEL=gpt-4.1-mini

# Comma-separated AAD object IDs of contacts allowed for auto-reply
ALLOWED_CONTACT_IDS=11111111-1111-1111-1111-111111111111,22222222-2222-2222-2222-222222222222

# Optional custom system behavior for replies
SYSTEM_PROMPT=You are a helpful assistant replying briefly and professionally in Microsoft Teams.
